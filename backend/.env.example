# ---- PocketScribe backend configuration ----
# Copy to .env and fill in. Never commit .env.

# Auth
DEVICE_PAIRING_TOKEN=change-me-long-random     # device must present this to /ingest
DASHBOARD_PASSWORD=change-me                    # login for the web dashboard

# Engine selection: "mock" (no keys, runs out of the box) or "cloud" (real).
# Start on mock to prove the flow, then switch both to cloud and add keys below.
TRANSCRIBE_ENGINE=mock
LLM_ENGINE=mock

# Cloud keys (needed only when engine = cloud)
OPENAI_API_KEY=                                 # Whisper transcription
ANTHROPIC_API_KEY=                              # Claude enrichment
ANTHROPIC_MODEL=claude-opus-4-8

# Local engines (Phase 3)
# WHISPER_MODEL=base                            # faster-whisper model size
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Language hints
LANGUAGES=de,en                                 # auto-detect between these

# Storage
DATA_DIR=/data                                  # audio files + sqlite db
KEEP_AUDIO=true                                 # retain raw audio after processing
MAX_MEETING_MINUTES=120
